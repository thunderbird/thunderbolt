{
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "6.0",
    "outDir": "bin",
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["index.ts", "src/**/*.ts", "../../shared/**/*.ts"]
}
