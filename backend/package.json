{
  "name": "thunderbolt-backend-elysia",
  "version": "0.1.0",
  "description": "Thunderbolt Backend rewritten with TypeScript + Elysia",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile server src/cluster.ts",
    "start": "./server",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "type-check": "bun tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "db": "drizzle-kit",
    "db:dev": "pglite-server --db=./.pglite/data",
    "email": "email dev --dir src/emails --port 3000"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.14",
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/jwt": "^1.4.0",
    "@elysiajs/opentelemetry": "^1.4.0",
    "@elysiajs/static": "^1.4.0",
    "@elysiajs/swagger": "^1.3.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.205.0",
    "@opentelemetry/sdk-trace-node": "^2.1.0",
    "@posthog/ai": "^6.4.1",
    "@react-email/components": "^1.0.10",
    "@types/bun": "^1.2.22",
    "better-auth": "^1.4.5",
    "bun-types": "^1.2.22",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "exa-js": "^2.11.0",
    "ipaddr.js": "^2.3.0",
    "jose": "^6.2.2",
    "openai": "^5.22.1",
    "pino": "^9.11.0",
    "postgres": "^3.4.7",
    "posthog-node": "^5.8.8",
    "rate-limiter-flexible": "^10.0.1",
    "resend": "^6.5.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite-socket": "^0.0.19",
    "@react-email/preview-server": "5.2.10",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "drizzle-kit": "^0.31.7",
    "eslint": "^9.39.2",
    "globals": "^16.4.0",
    "oauth2-mock-server": "^8.2.2",
    "pino-pretty": "^13.1.1",
    "prettier": "^3.2.4",
    "react-email": "^5.2.10",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
