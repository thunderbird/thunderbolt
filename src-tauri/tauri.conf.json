{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Thunderbolt",
  "version": "0.1.23",
  "identifier": "net.thunderbird.thunderbolt",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "scheme": [
            "thunderbolt",
            "com.googleusercontent.apps.860884698243-mqtkn10jk4q38ph2gkndc51q1fslqe69"
          ],
          "appLink": false
        }
      ],
      "desktop": {
        "schemes": [
          "thunderbolt"
        ]
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "Thunderbolt",
        "width": 1400,
        "height": 1000,
        "minHeight": 600,
        "minWidth": 600
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' tauri: asset:",
        "connect-src": "*",
        "img-src": "'self' asset: data:",
        "font-src": "'self' data:",
        "style-src": "'self' 'unsafe-inline'",
        "script-src": "'self' 'unsafe-inline' 'unsafe-eval' http://localhost:8000 https://thunderbolt-cloud.onrender.com"
      }
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "frameworks": [
        "MetalPerformanceShaders.framework",
        "MetalKit.framework",
        "Metal.framework"
      ],
      "developmentTeam": "BUMSKVQ3D9"
    },
    "android": {
      "versionCode": 1018
    }
  }
}
