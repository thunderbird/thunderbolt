# Thunderbolt Cloud URL (optional, defaults to http://localhost:8000)
# This URL is also used as the proxy for PostHog analytics
VITE_THUNDERBOLT_CLOUD_URL="http://localhost:8000"

# Posthog Analytics (optional)
# Get your API key from https://app.posthog.com/settings/project-details
VITE_POSTHOG_API_KEY=""

# Posthog Host (optional, defaults to https://us.i.posthog.com)
# Note: When VITE_THUNDERBOLT_CLOUD_URL is set, analytics will be proxied through it
# This direct host is kept for fallback purposes only
VITE_POSTHOG_HOST="https://us.i.posthog.com"

# Backend PostHog Host (optional, defaults to https://us.i.posthog.com)
# This configures which PostHog instance the backend proxy connects to
POSTHOG_HOST="https://us.i.posthog.com"