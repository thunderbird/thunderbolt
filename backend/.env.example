# Backend dev environment variables.
# Copy to .env: cp .env.example .env
# Then run `make doctor` — it generates BETTER_AUTH_SECRET for you.
#
# REQUIRED for the app to start:
#   - BETTER_AUTH_SECRET (auto-generated by `make doctor`)
#   - At least one AI provider key (ANTHROPIC_API_KEY / FIREWORKS_API_KEY / MISTRAL_API_KEY / THUNDERBOLT_INFERENCE_API_KEY)

# === Required: auth signing secret ===
# Used to sign bearer tokens and session cookies.
# Generate with `openssl rand -base64 32` or run `make doctor`.
BETTER_AUTH_SECRET=

# === Required: at least one AI provider ===
ANTHROPIC_API_KEY=
FIREWORKS_API_KEY=
MISTRAL_API_KEY=
THUNDERBOLT_INFERENCE_URL=https://animal.inference.thunderbolt.io/v1
THUNDERBOLT_INFERENCE_API_KEY=

# === Server ===
LOG_LEVEL=INFO
PORT=8000
APP_URL=http://localhost:1420

# === Database (matches `make up` — Docker Postgres on :5433 + PowerSync on :8080) ===
DATABASE_DRIVER=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/postgres
POWERSYNC_URL=http://localhost:8080
POWERSYNC_JWT_SECRET=powersync-dev-secret-change-in-production
POWERSYNC_JWT_KID=powersync-dev
POWERSYNC_TOKEN_EXPIRY_SECONDS=3600

# Alternative: PGlite (in-process, no Docker). Sync will not work in this mode — tests/experiments only.
# DATABASE_DRIVER=pglite
# DATABASE_URL=.pglite/data

# === Authentication ===
# AUTH_MODE: "consumer" for OTP, "oidc" / "saml" for enterprise SSO
AUTH_MODE=consumer
# Backend's public URL used for OIDC redirect URIs (must match what's registered with your IdP)
BETTER_AUTH_URL=http://localhost:8000
TRUSTED_ORIGINS=http://localhost:1420,http://localhost:8180

# === OIDC (only when AUTH_MODE=oidc) ===
# Works with any OIDC provider: Keycloak, Okta, Auth0, Entra ID, etc.
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ISSUER=
# Optional override. Defaults to `${OIDC_ISSUER}/.well-known/openid-configuration`.
# Use when the backend reaches the IdP at an internal hostname but tokens carry a browser-facing one.
OIDC_DISCOVERY_URL=

# === SAML (only when AUTH_MODE=saml) ===
SAML_ENTRY_POINT=
SAML_ENTITY_ID=
SAML_IDP_ISSUER=
SAML_CERT=

# === CORS — comma-separated list of exact origins (no wildcards) ===
# For preview deploys, append RENDER_EXTERNAL_URL in your start script.
CORS_ORIGINS=http://localhost:1420,tauri://localhost,http://tauri.localhost
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,Accept,Accept-Encoding,Accept-Language,Cache-Control,User-Agent,X-Requested-With,X-Client-Platform,X-Device-ID,X-Device-Name,X-Challenge-Token,X-Mcp-Target-Url,Mcp-Authorization,Mcp-Session-Id,Mcp-Protocol-Version
CORS_EXPOSE_HEADERS=mcp-session-id,set-auth-token,ratelimit-limit,ratelimit-remaining,ratelimit-reset,retry-after

# === Feature flags ===
# E2E encryption — set to "true" to require device trust flow before sync.
E2EE_ENABLED=false
# Swagger UI at /v1/swagger.
SWAGGER_ENABLED=false
# Rate limiting (set to false to disable entirely).
RATE_LIMIT_ENABLED=true

# === Waitlist ===
# When true, inference/pro routes require authentication.
WAITLIST_ENABLED=false
# Comma-separated list of email domains auto-approved for waitlist access.
WAITLIST_AUTO_APPROVE_DOMAINS=mozilla.org,thunderbird.net,mozilla.ai,mozilla.com

# === OAuth — optional, for Google/Microsoft sign-in alongside OIDC ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# === Observability — optional ===
# Health check token for /healthz auth.
MONITORING_TOKEN=
# Analytics.
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=
# OpenTelemetry tracing (leave empty to disable).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TOKEN=

# === External APIs — optional ===
# Web search via Exa.
EXA_API_KEY=

# === Trusted proxy ===
# Controls which proxy headers are trusted for IP extraction in rate limiting.
# Set to 'cloudflare' to trust CF-Connecting-IP, 'akamai' for True-Client-IP.
# Leave empty to use the direct socket IP only (all proxy headers ignored).
TRUSTED_PROXY=
