# Health Check Configuration
MONITORING_TOKEN=

# OAuth Settings
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# General settings
LOG_LEVEL=INFO
PORT=8000

# Fireworks
FIREWORKS_API_KEY=""

# Mistral
MISTRAL_API_KEY=""

# Anthropic
ANTHROPIC_API_KEY=""

# Thunderbolt
THUNDERBOLT_INFERENCE_URL="https://animal.inference.thunderbolt.io/v1"
