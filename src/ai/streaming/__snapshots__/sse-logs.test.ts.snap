exports[`SSE -> UIMessage: banana 1`] = `
"{
  "id": "<DYNAMIC_ID>",
  "metadata": {
    "modelId": "simulator"
  },
  "role": "assistant",
  "parts": [
    {
      "type": "step-start"
    },
