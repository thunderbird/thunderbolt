# Thunderbolt Cloud URL (optional, defaults to http://localhost:8000)
VITE_THUNDERBOLT_CLOUD_URL="http://localhost:8000/v1"

# Bypass waitlist routes for UI development (set to "true" to skip waitlist)
# Note: This only bypasses frontend routing, not backend auth
# VITE_BYPASS_WAITLIST="true"

# Auth mode — set to "sso" for enterprise SSO (OIDC or SAML), omit for consumer
# VITE_AUTH_MODE="sso"

# Enable anonymous-session auto-creation as an overlay on the primary auth path.
# When "true", unauthenticated visitors on bypass-waitlist deployments (or PR previews)
# silently receive an anonymous session. Mutually exclusive with SSO mode.
# Backend mirror: AUTH_ALLOW_ANONYMOUS must also be "true" for the endpoint to exist.
VITE_AUTH_ENABLE_ANONYMOUS=false

# Show app download links/banners in the web UI (set to "true" for internal testing deployments)
# When enabled, desktop users see a sidebar section + bottom-right banner; mobile users see a top banner
# VITE_SHOW_APP_DOWNLOADS="true"
