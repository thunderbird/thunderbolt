---
import BaseLayout from './BaseLayout.astro';

type Props = {
	title: string;
	description: string;
	date: Date;
	author: string;
	tags: string[];
	image?: string;
};

const { title, description, date, author, tags, image } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<BaseLayout title={title} description={description} ogType="article">
	<article>
		<header class="post-header">
			{
				tags.length > 0 && (
					<div class="tags">
						{tags.map((tag) => (
							<span class="tag">{tag}</span>
						))}
					</div>
				)
			}
			<h1>{title}</h1>
			<p class="meta">
				<span class="author">{author}</span>
				<span class="sep">&middot;</span>
				<time datetime={date.toISOString()}>{formattedDate}</time>
			</p>
		</header>
		{image && <img src={image} alt="" class="cover" />}
		<div class="prose">
			<slot />
		</div>
	</article>
</BaseLayout>

<style>
	article {
		max-width: 100%;
	}

	.post-header {
		margin-bottom: 2.5rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--tb-border);
	}

	.post-header h1 {
		font-size: clamp(2rem, 4vw, 2.5rem);
		line-height: 1.15;
		letter-spacing: -0.025em;
		font-weight: 500;
		color: var(--tb-text);
		margin: 0.75rem 0 0.75rem;
	}

	.meta {
		color: var(--tb-text-muted);
		font-size: 0.875rem;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin: 0;
	}

	.meta .author {
		color: var(--tb-text-secondary);
		font-weight: 500;
	}

	.meta .sep {
		color: var(--tb-text-dim);
	}

	.tags {
		display: flex;
		gap: 0.375rem;
	}

	.tag {
		font-family: var(--tb-font-mono);
		font-size: 0.6875rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		padding: 0.25rem 0.55rem;
		background: var(--tb-surface);
		border: 1px solid var(--tb-border);
		color: var(--tb-text-muted);
	}

	.cover {
		width: 100%;
		margin-bottom: 2rem;
		border: 1px solid var(--tb-border);
	}

	/* ─── Editorial prose (matches marketing .prose-thunderbolt) ─── */
	.prose {
		font-family: var(--tb-font-sans);
		color: var(--tb-text-secondary);
		font-size: 1.0625rem;
		line-height: 1.75;
	}

	.prose :global(p) {
		margin-top: 1.5em;
		margin-bottom: 0;
	}

	.prose :global(p:first-child) {
		margin-top: 0;
	}

	.prose :global(h2) {
		margin-top: 2.5em;
		margin-bottom: 0.75em;
		font-size: 1.5rem;
		font-weight: 500;
		line-height: 1.3;
		letter-spacing: -0.015em;
		color: var(--tb-text);
	}

	.prose :global(h3) {
		margin-top: 2em;
		margin-bottom: 0.5em;
		font-size: 1.1875rem;
		font-weight: 500;
		color: var(--tb-text);
	}

	.prose :global(ul),
	.prose :global(ol) {
		margin-top: 1.25em;
		margin-bottom: 0;
		padding-left: 1.5em;
	}

	.prose :global(ul) {
		list-style: disc;
	}

	.prose :global(li) {
		margin-top: 0.5em;
	}

	.prose :global(li + li) {
		margin-top: 0.75em;
	}

	.prose :global(strong) {
		font-weight: 600;
		color: var(--tb-text);
	}

	.prose :global(a) {
		color: var(--tb-text);
		text-decoration: none;
		border-bottom: 1px solid color-mix(in srgb, var(--tb-text-muted) 40%, transparent);
		transition:
			color 0.15s,
			border-color 0.15s;
	}

	.prose :global(a:hover) {
		color: var(--tb-text);
		border-color: var(--tb-text);
	}

	.prose :global(code) {
		background: var(--tb-surface-input);
		border: 1px solid var(--tb-border);
		padding: 0.05em 0.35em;
		font-family: var(--tb-font-mono);
		font-size: 0.85em;
		color: var(--tb-text);
	}

	.prose :global(pre) {
		background: var(--tb-surface);
		border: 1px solid var(--tb-border);
		padding: 1.15rem 1.25rem;
		overflow-x: auto;
		margin: 1.5em 0;
		font-size: 0.875rem;
		line-height: 1.55;
	}

	.prose :global(pre code) {
		background: none;
		border: 0;
		padding: 0;
		color: var(--tb-text);
		font-size: inherit;
	}

	.prose :global(blockquote) {
		margin: 2em 0 0;
		border-left: 3px solid var(--tb-border);
		padding-left: 1.25em;
		font-size: 1.125rem;
		line-height: 1.6;
		color: var(--tb-text);
		font-style: italic;
	}

	.prose :global(blockquote cite) {
		display: block;
		margin-top: 0.75em;
		font-style: normal;
		font-size: 0.875rem;
		font-weight: 500;
		color: var(--tb-text-muted);
	}

	.prose :global(img) {
		max-width: 100%;
		border: 1px solid var(--tb-border);
	}

	.prose :global(hr) {
		margin: 2.5em 0;
		border: 0;
		border-top: 1px solid var(--tb-border);
	}
</style>
