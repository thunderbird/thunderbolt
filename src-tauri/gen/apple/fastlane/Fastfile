# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#     https://docs.fastlane.tools/plugins/available-plugins

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # Skip git status check in CI environment
    if ENV["CI"]
      puts "Running in CI environment, skipping git status check"
    else
      ensure_git_status_clean
    end
    
    # Set version if provided via workflow input
    if ENV["VERSION_INPUT"] && !ENV["VERSION_INPUT"].empty?
      puts "📝 Setting version to: #{ENV['VERSION_INPUT']}"
      increment_version_number(
        version_number: ENV["VERSION_INPUT"],
        xcodeproj: "thunderbolt.xcodeproj"
      )
    end
    
    # Increment build number automatically
    increment_build_number(
      xcodeproj: "thunderbolt.xcodeproj"
    )
    
    # Set development team before building
    if ENV["APPLE_TEAM_ID"] && !ENV["APPLE_TEAM_ID"].empty?
      update_project_team(
        path: "thunderbolt.xcodeproj",
        teamid: ENV["APPLE_TEAM_ID"]
      )
    end
    
    # Set provisioning profile
    profile_path = Dir.glob(File.expand_path("~/Library/MobileDevice/Provisioning Profiles/*.mobileprovision")).first
    if profile_path
      update_project_provisioning(
        xcodeproj: "thunderbolt.xcodeproj",
        profile: profile_path,
        target_filter: "thunderbolt_iOS"
      )
    end
    
    # Build the app
    build_app(
      scheme: "thunderbolt_iOS",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        teamID: ENV["APPLE_TEAM_ID"],
        signingStyle: "manual",
        uploadBitcode: false,
        uploadSymbols: true,
        compileBitcode: false,
        destination: "export"
      }
    )
    
    # Authenticate with App Store Connect API key
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"], 
      key_filepath: "./fastlane/AuthKey_#{ENV['ASC_KEY_ID']}.p8"
    )
    
    # Upload to TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      distribute_external: false,
      notify_external_testers: false,
      changelog: "Automated build from GitHub Actions",
      uses_non_exempt_encryption: false
    )
    
    puts "🚀 Successfully uploaded to TestFlight!"
  end

  desc "Deploy pre-built app to TestFlight"
  lane :deploy_only do
    # Skip git status check in CI environment
    if ENV["CI"]
      puts "Running in CI environment, skipping git status check"
    else
      ensure_git_status_clean
    end
    
    # Set version if provided via workflow input
    if ENV["VERSION_INPUT"] && !ENV["VERSION_INPUT"].empty?
      puts "📝 Setting version to: #{ENV['VERSION_INPUT']}"
      increment_version_number(
        version_number: ENV["VERSION_INPUT"],
        xcodeproj: "thunderbolt.xcodeproj"
      )
    end
    
    # Increment build number automatically
    increment_build_number(
      xcodeproj: "thunderbolt.xcodeproj"
    )
    
    # Set development team
    if ENV["APPLE_TEAM_ID"] && !ENV["APPLE_TEAM_ID"].empty?
      update_project_team(
        path: "thunderbolt.xcodeproj",
        teamid: ENV["APPLE_TEAM_ID"]
      )
    end
    
    # Set provisioning profile
    profile_path = Dir.glob(File.expand_path("~/Library/MobileDevice/Provisioning Profiles/*.mobileprovision")).first
    if profile_path
      update_project_provisioning(
        xcodeproj: "thunderbolt.xcodeproj",
        profile: profile_path,
        target_filter: "thunderbolt_iOS"
      )
    end
    
    # Find the pre-built app
    app_path = Dir.glob("#{ENV['GITHUB_WORKSPACE']}/src-tauri/target/aarch64-apple-ios/release/bundle/iOS/*.app").first
    
    if app_path && File.exist?(app_path)
      puts "📱 Found pre-built app at: #{app_path}"
      
      # Copy app to expected location
      FileUtils.cp_r(app_path, ".")
      app_name = File.basename(app_path)
      
      # Archive and export
      gym(
        scheme: "thunderbolt_iOS",
        archive_path: "./Thunderbolt.xcarchive",
        export_method: "app-store",
        export_options: {
          method: "app-store",
          teamID: ENV["APPLE_TEAM_ID"],
          signingStyle: "manual",
          uploadBitcode: false,
          uploadSymbols: true,
          compileBitcode: false
        },
        skip_build_archive: false
      )
      
      # Authenticate with App Store Connect API key
      app_store_connect_api_key(
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"], 
        key_filepath: "./fastlane/AuthKey_#{ENV['ASC_KEY_ID']}.p8"
      )
      
      # Upload to TestFlight
      upload_to_testflight(
        skip_waiting_for_build_processing: true,
        skip_submission: true,
        distribute_external: false,
        notify_external_testers: false,
        changelog: "Automated build from GitHub Actions",
        uses_non_exempt_encryption: false
      )
      
      puts "🚀 Successfully uploaded pre-built app to TestFlight!"
    else
      puts "❌ No pre-built app found. Expected at: #{ENV['GITHUB_WORKSPACE']}/src-tauri/target/aarch64-apple-ios/release/bundle/iOS/*.app"
      exit(1)
    end
  end
  
  desc "Build for App Store release"
  lane :release do
    # Ensure we're in the right directory
    ensure_git_status_clean
    
    # Build the app
    build_app(
      scheme: "thunderbolt_iOS",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        teamID: ENV["APPLE_TEAM_ID"],
        signingStyle: "manual"
      }
    )
    
    # Upload to App Store Connect for review
    upload_to_app_store(
      force: true,
      reject_if_possible: true,
      skip_metadata: false,
      skip_screenshots: false,
      submit_for_review: false
    )
  end
  
  desc "Download certificates and provisioning profiles"
  lane :certificates do
    # Option 1: Use match (recommended for team development)
    # match(type: "appstore")
    
    # Option 2: Use cert and sigh for manual certificate management
    cert
    sigh(force: true)
  end
  
  desc "Verify provisioning profile has required capabilities"
  lane :verify_profile do
    profile_path = Dir.glob(File.expand_path("~/Library/MobileDevice/Provisioning Profiles/*.mobileprovision")).first
    
    if profile_path.nil?
      UI.error("❌ No provisioning profile found")
      exit(1)
    end
    
    # Read the profile
    profile_content = `security cms -D -i "#{profile_path}"`
    
    # Check for Associated Domains
    if profile_content.include?("com.apple.developer.associated-domains")
      UI.success("✅ Provisioning profile includes Associated Domains capability")
    else
      UI.error("❌ Provisioning profile does NOT include Associated Domains capability")
      UI.error("   Please create a new profile with this capability enabled")
      exit(1)
    end
    
    # Show profile details
    profile_name = `security cms -D -i "#{profile_path}" | plutil -extract Name raw -`.strip
    profile_uuid = `security cms -D -i "#{profile_path}" | plutil -extract UUID raw -`.strip
    team_id = `security cms -D -i "#{profile_path}" | plutil -extract TeamIdentifier.0 raw -`.strip
    
    UI.success("Profile Name: #{profile_name}")
    UI.success("Profile UUID: #{profile_uuid}")
    UI.success("Team ID: #{team_id}")
  end
  
  desc "Run tests"
  lane :test do
    run_tests(
      scheme: "thunderbolt_iOS",
      device: "iPhone 15 Pro"
    )
  end
  
  # Error handling
  error do |lane, exception|
    # slack(
    #   message: "Error occurred in lane #{lane}: #{exception}",
    #   success: false
    # )
  end
end