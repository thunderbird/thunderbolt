{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Thunderbolt",
  "version": "0.1.0",
  "identifier": "org.mozilla.thunderbolt",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Thunderbolt",
        "width": 1400,
        "height": 1000,
        "minHeight": 600,
        "minWidth": 600
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": ["script-src", "style-src"],
      "pattern": {
        "use": "isolation",
        "options": {
          "dir": "../dist-isolation"
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "iOS": {
      "frameworks": ["MetalPerformanceShaders.framework", "MetalKit.framework", "Metal.framework"]
    }
  }
}
