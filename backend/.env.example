# API Keys
FIREWORKS_API_KEY=
FLOWER_MGMT_KEY=
FLOWER_PROJ_ID=
EXA_API_KEY=

# Health Check Configuration
MONITORING_TOKEN=

# OAuth Settings
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# General settings
LOG_LEVEL=INFO
PORT=8000

# Analytics settings
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=

# CORS settings
CORS_ORIGINS=http://localhost:1420
CORS_ORIGIN_REGEX=
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOW_HEADERS=*
CORS_EXPOSE_HEADERS=mcp-session-id

# OpenTelemetry settings (optional)
# Leave empty to disable OpenTelemetry tracing
OTEL_EXPORTER_OTLP_ENDPOINT=
# Format: key1=value1,key2=value2
OTEL_EXPORTER_OTLP_HEADERS=
