{
  "extends": "../shared/tsconfig.base.json",
  "compilerOptions": {
    "target": "ESNext",
    "composite": false,
    "ignoreDeprecations": "6.0",
    "verbatimModuleSyntax": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["../shared/*"]
    },
    "types": ["bun-types"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "test/**/*.ts",
    "../shared/acp-types.ts",
    "../shared/powersync-tables.ts",
    "../shared/proxy-protocol.ts",
    "../shared/url.ts",
    "../shared/ws-bearer.ts",
    "../shared/types/auth.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
