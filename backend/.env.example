# Thunderbolt Backend Environment Variables

# Google OAuth Configuration
# To set up Google OAuth:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select an existing one
# 3. Enable the Gmail API
# 4. Go to "Credentials" and create an OAuth 2.0 Client ID
# 5. Set Application Type to "Desktop app"
# 6. Add authorized redirect URI: http://localhost:1420/oauth/callback
# 7. Copy the Client ID and Client Secret below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth Configuration (Future)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Fireworks API Configuration (Optional)
FIREWORKS_API_KEY=

# Flower AI Configuration (Optional)
FLOWER_MGMT_KEY=
FLOWER_PROJ_ID=

# Exa
EXA_API_KEY=

# PostHog
POSTHOG_HOST="https://us.i.posthog.com"
POSTHOG_API_KEY=

# Server Configuration
LOG_LEVEL=INFO
CORS_ORIGINS="http://localhost:1420"
CORS_ALLOW_CREDENTIALS=true

# Health Check Configuration
MONITORING_TOKEN="your_secret_monitoring_token_here"
