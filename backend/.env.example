# Authentication
TRUSTED_ORIGINS="http://localhost:1420"

# CORS settings
CORS_ORIGINS=http://localhost:1420
CORS_ORIGIN_REGEX=
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOW_HEADERS=*
CORS_EXPOSE_HEADERS=mcp-session-id

# OpenTelemetry settings (optional)
# Leave empty to disable OpenTelemetry tracing
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TOKEN=

# Database
DATABASE_DRIVER="pglite"
DATABASE_URL=".pglite/data"

