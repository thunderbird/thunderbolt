# Copy to secrets.yaml and fill in base64-encoded values:
#   echo -n "your-value" | base64
apiVersion: v1
kind: Secret
metadata:
  name: thunderbolt-secrets
  namespace: thunderbolt
type: Opaque
data:
  # echo -n "thunderbolt-enterprise-secret" | base64
  oidc-client-secret: dGh1bmRlcmJvbHQtZW50ZXJwcmlzZS1zZWNyZXQ=
  # echo -n "enterprise-powersync-secret" | base64
  powersync-jwt-secret: ZW50ZXJwcmlzZS1wb3dlcnN5bmMtc2VjcmV0
  # echo -n "postgres" | base64
  postgres-password: cG9zdGdyZXM=
