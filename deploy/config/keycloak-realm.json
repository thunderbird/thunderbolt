{
  "realm": "thunderbolt",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "clients": [
    {
      "clientId": "thunderbolt-app",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "thunderbolt-enterprise-secret",
      "redirectUris": ["${OIDC_REDIRECT_URI:http://localhost:3000/v1/api/auth/oauth2/callback/oidc}"],
      "webOrigins": ["${OIDC_WEB_ORIGIN:http://localhost:3000}"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "publicClient": false,
      "protocol": "openid-connect",
      "defaultClientScopes": [
        "openid",
        "profile",
        "email"
      ]
    }
  ],
  "users": [
    {
      "username": "demo",
      "email": "demo@thunderbolt.io",
      "firstName": "Demo",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "demo",
          "temporary": false
        }
      ]
    }
  ]
}
